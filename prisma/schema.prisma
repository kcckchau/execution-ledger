generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Existing enums — extended backward-compatibly.
// Legacy values (already in production data) are kept and marked.
// ─────────────────────────────────────────────────────────────────────────────

enum SetupType {
  // Legacy values retained for existing rows.
  FLIP
  VWAP_RECLAIM
  VWAP_REJECT
  VWAP_PULLBACK
  ORB_BREAK
  SWEEP_FAIL
  FAILED_BREAKOUT
  FAILED_BREAKDOWN
  RANGE_RECLAIM
  RANGE_REJECT
  TREND_PULLBACK
  BREAKOUT
  BREAKDOWN
  RANGE
  FAILED_MOVE
  VWAP_PLAY
}

enum Regime {
  UP
  DOWN
  RANGE
  // New values
  CHOP
  TRANSITION
}

/// Trade-relative alignment (whether the trade direction aligns with the prevailing regime).
/// WITH_TREND is the legacy name; WITH is the canonical new alias added in migration intelligence_refactor.
/// COUNTER is retained for existing data.
/// NEUTRAL added for flat or ambiguous regime conditions.
enum Alignment {
  // Legacy values — in production data; kept for backward compat.
  WITH_TREND
  COUNTER
  // Canonical new values
  WITH
  NEUTRAL
}

enum Transition {
  NONE
  FLIP
  FAILED_FLIP
}

// ─────────────────────────────────────────────────────────────────────────────
// New enums added for analytics-ready classification
// ─────────────────────────────────────────────────────────────────────────────

/// Used for new structured fields; NOT yet applied to TradeSetup.direction (String for compat).
enum Direction {
  LONG
  SHORT
}

enum VWAPState {
  ABOVE_ACCEPT
  BELOW_ACCEPT
  REJECTING_FROM_ABOVE
  REJECTING_FROM_BELOW
  CHOP_AROUND
}

enum DayType {
  TREND
  CHOP
  RANGE
  OPEN_DRIVE
  OPEN_REJECTION
  TRANSITION
}

enum Trigger {
  RECLAIM_LEVEL
  BREAK_AND_HOLD
  STRONG_ENGULF
  MOMENTUM_SHIFT
  LIQUIDITY_SWEEP
  FAILURE_CONFIRM
}

enum TradeLocation {
  ABOVE_VWAP
  BELOW_VWAP
  AT_VWAP
}

enum LiquidityContext {
  SWEEP_HIGH
  SWEEP_LOW
  NONE
}

enum KeyLevel {
  PDH
  PDL
  PREMARKET_HIGH
  PREMARKET_LOW
  RANGE_HIGH
  RANGE_LOW
  VWAP
  WHOLE_NUMBER
}

enum EntryType {
  AGGRESSIVE
  PULLBACK
}

enum EntryTiming {
  EARLY
  IDEAL
  LATE
}

enum Confirmation {
  HOLD_ABOVE_LEVEL
  HOLD_BELOW_LEVEL
  FOLLOW_THROUGH
}

enum StructureType {
  HH_HL
  LH_LL
  RANGE
  BREAKOUT_FAIL
  BREAKDOWN_FAIL
  REVERSAL
}

enum TriggerType {
  VWAP_RECLAIM
  VWAP_REJECT
  ORB_BREAK
  SWEEP_FAIL
  RANGE_HIGH_REJECT
  RANGE_LOW_RECLAIM
  BREAKOUT_CONFIRM
  BREAKDOWN_CONFIRM
}

enum MistakeTag {
  EARLY_ENTRY
  LATE_ENTRY
  CHASE
  COUNTER_TREND
  NO_CONFIRMATION
  OVERTRADE
  WRONG_LEVEL
  IGNORED_VWAP
  IGNORED_STRUCTURE
  BAD_STOP
  BAD_TARGET
  SIZE_TOO_BIG
  EMOTIONAL_TRADE
  SHOULD_HAVE_SKIPPED
}

enum OutcomeType {
  WIN
  LOSS
  NEUTRAL
  STRONG_WIN
  STRONG_LOSS
}

enum MissReason {
  DID_NOT_SEE
  HESITATION
  DISTRACTION
  NO_PLAN
  LOW_CONFIDENCE
  EXECUTION_DELAY
  RISK_LIMIT_REACHED
}

// ─────────────────────────────────────────────────────────────────────────────
// 4-part classification model enums
// ─────────────────────────────────────────────────────────────────────────────

/// Market conditions / confluence state when the trade was taken.
/// Multi-select — edge comes from combinations (e.g. TREND + ABOVE_VWAP).
enum Context {
  TREND
  RANGE
  TRANSITION
  ABOVE_VWAP
  BELOW_VWAP
}

/// Specific price levels that formed the battlefield for the trade.
/// Multi-select — more locations = higher confluence.
enum Location {
  RANGE_HIGH
  RANGE_LOW
  MID_RANGE
  PDH
  PDL
  PREMARKET_HIGH
  PREMARKET_LOW
  AH_HIGH
  AH_LOW
  VWAP
  WHOLE_NUMBER
}

/// Exact execution timing signal — what candle/pattern triggered the entry.
/// Single-select; distinct from SetupType (WHY) and Location (WHERE).
enum EntryTrigger {
  EMA9_21_BULLISH_CROSS
  EMA9_21_BEARISH_CROSS
  BREAK_STRUCTURE
  REJECTION_CANDLE
}

/// Structured condition that invalidates the trade idea.
/// Stored instead of (or alongside) free-text invalidation for analytics.
enum InvalidationType {
  RECLAIM_VWAP
  BREAK_RANGE_HIGH
  BREAK_RANGE_LOW
  HOLD_ABOVE_VWAP
  HOLD_BELOW_VWAP
  STRUCTURE_BREAK
}

// ─────────────────────────────────────────────────────────────────────────────
// Review layer enums — post-trade analysis
// ─────────────────────────────────────────────────────────────────────────────

/// What the trader was trying to capture.
enum ReviewIntent {
  TREND_CONTINUATION
  REVERSAL
  RANGE_PLAY
  BREAKOUT
  FAILED_MOVE_TRAP
}

/// Monetary outcome of the trade.
/// @deprecated Use TradeResult instead.
enum Outcome {
  WIN
  LOSS
  BREAKEVEN
}

/// Whether the setup idea itself was correct, independent of P&L.
/// @deprecated Use SetupValidity instead.
enum SetupResult {
  PLAYED_OUT
  FAILED
  UNCLEAR
}

/// Monetary outcome of the trade.
enum TradeResult {
  WIN
  LOSS
  BREAKEVEN
}

/// Whether the setup read was correct, wrong, or partially right.
enum SetupValidity {
  CORRECT_READ
  WRONG_READ
  PARTIAL
}

/// Category of execution or planning mistake.
/// Multi-select — multiple mistakes can apply to a single trade.
enum MistakeType {
  BAD_SETUP
  WRONG_CONTEXT
  BAD_LOCATION
  EARLY_ENTRY
  LATE_ENTRY
  NO_TRIGGER
  WRONG_STOP
  NO_PLAN
  EMOTIONAL
}

/// What the market actually did after entry, regardless of the trade's P&L.
enum MarketOutcome {
  VWAP_RECLAIM
  VWAP_REJECT
  TREND_CONTINUATION
  RANGE_CONTINUATION
  TREND_UP
  TREND_DOWN
  RANGE_CHOP
  FAILED_MOVE
  BREAKOUT_CONTINUATION
  REVERSAL
}

// ─────────────────────────────────────────────────────────────────────────────
// TradeSetup — for trades that were executed or actively planned.
// Structured as three analytical layers.
// ─────────────────────────────────────────────────────────────────────────────

model TradeSetup {
  id        String    @id @default(cuid())
  /// Stored as YYYY-MM-DD in America/New_York trading-day semantics.
  /// DO NOT convert to DateTime without a careful timezone-aware migration.
  setupDate String
  symbol    String
  /// @legacy — restricted to "long" | "short" (lowercase). Do NOT store any other value.
  /// Use bestDirection (Direction enum) for new structured reflection fields.
  /// TODO: migrate to Direction enum once API/UI code is updated.
  direction String

  setupType SetupType @default(RANGE)
  triggers  Trigger[] @default([])
  dayType   DayType?
  location  TradeLocation?
  liquidityContext LiquidityContext?
  keyLevels KeyLevel[] @default([])
  entryType EntryType?
  entryTiming EntryTiming?
  confirmation Confirmation[] @default([])

  // ── Layer 1 legacy: free-text planning fields (retained for backward compat) ──
  /// Free-text trigger description. Structured equivalent: triggerType.
  trigger        String
  /// Free-text decision target / idea objective.
  decisionTarget String
  /// Free-text entry level. Numeric equivalent: entryPrice.
  riskEntry      String
  /// Free-text stop level. Numeric equivalent: stopPrice.
  riskStop       String
  /// Free-text target level. Numeric equivalent: targetPrice.
  riskTarget     String

  // ── Layer 1 structured: trade planning ──
  triggerType  TriggerType?
  entryPrice   Float?
  stopPrice    Float?
  targetPrice  Float?

  // ── Structured invalidation ──
  /// Enum condition that voids the trade idea — required for analytics.
  invalidationType InvalidationType @default(STRUCTURE_BREAK)
  /// Optional free-text nuance on top of the structured type.
  invalidationNote String?

  // ── 4-part classification model ──
  /// WHY — already captured by setupType above.
  /// WHEN it works — market conditions at entry (multi-select, required ≥1 for new records).
  contexts     Context[]    @default([])
  /// WHERE — exact price levels forming the battlefield (multi-select, optional).
  locations    Location[]   @default([])
  /// HOW to enter — execution timing signal (single, required for new records).
  entryTrigger EntryTrigger?

  // ── Layer 2: per-trade market reality at/around entry ──
  /// Market regime at the time this specific trade was entered.
  /// Distinct from DayContext.initialRegime (day open) and DayContext.entryRegime (session-wide).
  trueRegime Regime?
  /// VWAP state at the time of entry.
  vwapState  VWAPState?
  /// Price structure observed at entry.
  structure  StructureType?
  /// Whether this trade was with or counter to the prevailing regime.
  /// Trade-relative; this field belongs here, NOT on DayContext.
  alignment  Alignment?

  // ── Grading / status ──
  initialGrade String?
  status       String  @default("open")
  // TODO: Add a completion lifecycle enum (DRAFT | REVIEWED | COMPLETE) once
  //       API and UI code no longer depend solely on the "open"/"closed" status string.
  overallNotes String  @default("")
  setupName    String?

  // ── Layer 3: reflection ──
  mistakeTags     MistakeTag[] @default([])
  executionScore  Int?
  readScore       Int?
  disciplineScore Int?
  bestSetupType   SetupType?
  /// Reflection on best direction as a structured enum.
  /// The primary `direction` field stays as String — see note above.
  bestDirection   Direction?
  shouldTrade     Boolean?

  // ── Review layer — post-trade analysis ──
  /// What the trader intended to capture.
  intent        ReviewIntent?
  /// @deprecated Legacy review outcome retained for compatibility only.
  outcome       Outcome?
  /// Monetary outcome: did the trade make or lose money.
  tradeResult   TradeResult?
  /// @deprecated Legacy setup-quality field retained for compatibility only.
  setupResult   SetupResult?
  /// Whether the setup read was actually correct.
  setupValidity SetupValidity?
  /// What execution or planning mistakes were made (multi-select).
  mistakeTypes  MistakeType[] @default([])
  /// What the market actually did after entry.
  marketOutcome MarketOutcome?
  /// Free-text post-trade note.
  reviewNote    String?

  /// When true this setup is an ideal/hypothetical trade for review purposes only.
  /// Ideal setups: hypothetical; app UI tracks P&L separately from executed setups.
  isIdeal Boolean @default(false)

  executions Execution[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([setupDate, setupType])
  @@index([setupDate, isIdeal])
  @@index([trueRegime, vwapState])
  @@index([alignment, shouldTrade])
  @@index([entryTrigger])
  @@index([tradeResult, setupValidity])
}

// ─────────────────────────────────────────────────────────────────────────────
// DayContext — day-wide market character shared across all setups for a date.
// NOT for per-trade conditions (use TradeSetup Layer 2 for those).
// ─────────────────────────────────────────────────────────────────────────────

model DayContext {
  id   String @id @default(cuid())
  /// YYYY-MM-DD — one record per calendar trading day.
  date String @unique

  /// @legacy — free-text market context string (e.g. "uptrend", "range").
  /// Superseded by dayType enum. Kept for migration safety.
  /// TODO: drop after backfilling dayType from marketContext values.
  marketContext String?
  /// Structured day type, replacing the legacy marketContext string.
  dayType       DayType?

  /// Market regime at the open / early session.
  initialRegime Regime?
  /// Market regime that prevailed during the active trading session (day-wide aggregate).
  /// Distinct from TradeSetup.trueRegime which is the regime at a specific trade's entry.
  entryRegime   Regime?

  transition Transition?

  // alignment removed — trade-relative, not day-wide. Lives on TradeSetup.alignment.
  // DB column was dropped in migration 20260404000000_intelligence_refactor.

  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Execution — unchanged; preserved exactly for backward compat.
// ─────────────────────────────────────────────────────────────────────────────

model Execution {
  id            String     @id @default(cuid())
  setupId       String
  actionType    String
  price         Float
  size          Int
  executionTime DateTime
  note          String     @default("")
  setup         TradeSetup @relation(fields: [setupId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// ChartMarker — unchanged; soft FK columns preserved.
// ─────────────────────────────────────────────────────────────────────────────

model ChartMarker {
  id             String   @id
  symbol         String
  tradeDate      String
  executionTime  DateTime
  side           String
  shares         Float
  price          Float
  executionType  String
  positionEffect String
  source         String   @default("ibkr")
  externalId     String
  markerShape    String
  markerColor    String
  markerText     String
  /// Soft FK → Execution.id. Null for legacy records imported before this column existed.
  executionId    String?
  /// Soft FK → TradeSetup.id. Set at import time; null for legacy records.
  setupId        String?
  createdAt      DateTime @default(now())

  @@unique([symbol, tradeDate, externalId])
  @@index([symbol, tradeDate])
  @@index([setupId])
}
