generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SetupType {
  VWAP_RECLAIM
  VWAP_REJECT
  BREAKOUT
  BREAKDOWN
  RANGE
  FLIP
}

enum Regime {
  UP
  DOWN
  RANGE
}

enum Transition {
  NONE
  FLIP
  FAILED_FLIP
}

enum Alignment {
  WITH_TREND
  COUNTER
}

model TradeSetup {
  id             String      @id
  setupDate      String
  symbol         String
  direction      String
  setupType      SetupType   @default(RANGE)
  trigger        String
  invalidation   String
  decisionTarget String
  riskEntry      String
  riskStop       String
  riskTarget     String
  initialGrade   String?
  status         String      @default("open")
  overallNotes   String      @default("")
  /// Optional free-text name shown in the chart toggle UI (e.g. "Morning VWAP play").
  /// Falls back to setupType + instance index when null.
  setupName      String?
  /// Stored as JSON: { followedPlan, wentWell, failed, lesson }
  review         Json?
  executions     Execution[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

/// Day-level market context shared by all setups on the same trading date.
/// Replaces the per-setup marketContext / initialRegime / entryRegime / transition / alignment fields.
model DayContext {
  id            String      @id @default(cuid())
  /// YYYY-MM-DD — primary dimension, one record per calendar trading day.
  date          String      @unique
  marketContext String?
  initialRegime Regime?
  entryRegime   Regime?
  transition    Transition?
  alignment     Alignment?
  notes         String      @default("")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Execution {
  id            String     @id
  setupId       String
  actionType    String
  price         Float
  size          Int
  executionTime DateTime
  note          String     @default("")
  setup         TradeSetup @relation(fields: [setupId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ChartMarker {
  id             String   @id
  symbol         String
  tradeDate      String
  executionTime  DateTime
  side           String
  shares         Float
  price          Float
  executionType  String
  positionEffect String
  source         String   @default("ibkr")
  externalId     String
  markerShape    String
  markerColor    String
  markerText     String
  /// Soft FK → Execution.id ("exec-" + externalId). Null for markers imported
  /// before this column was added (backfilled by migration).
  executionId    String?
  /// Soft FK → TradeSetup.id. Set at import time; null for legacy records.
  setupId        String?
  createdAt      DateTime @default(now())

  @@unique([symbol, tradeDate, externalId])
  @@index([symbol, tradeDate])
  @@index([setupId])
}
