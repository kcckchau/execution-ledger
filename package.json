{
  "name": "execution-ledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "import:markers": "tsx scripts/import-markers.ts",
    "convert:csv": "tsx scripts/convert-ibkr-csv.ts",
    "import:csv": "sh -c 'csv=\"$1\"; symbol=\"$2\"; date=\"$3\"; compact_date=$(printf %s \"$date\" | tr -d \"-\"); pnpm convert:csv \"$csv\" \"$symbol\" && pnpm import:markers \"$symbol\" \"$date\" \"./data/trades/$symbol/${compact_date}-markers.json\" --replace' --"
  },
  "dependencies": {
    "lightweight-charts": "^5.1.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
