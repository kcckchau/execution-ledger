# Copy this file to .env and fill in your database URLs.
#
# Supabase: Settings → Database → Connection string
#   DATABASE_URL  → "Connection pooling" tab (port 6543) — used by the app at runtime
#   DIRECT_URL    → "URI" tab (port 5432)               — used by Prisma CLI (migrate/push)
#
# Neon: use the same URL for both, append ?sslmode=require

DATABASE_URL="postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
